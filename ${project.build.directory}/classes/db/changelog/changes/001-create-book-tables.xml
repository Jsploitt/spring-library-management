<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="moutaz" dbms="mysql">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="book"/>
            </not>
        </preConditions>

        <!-- Parent table -->
        <createTable tableName="book">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="isbn" type="INTEGER">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="author" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="genre" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="ref_code" type="VARCHAR(10)"/>
        </createTable>

        <!-- AudioBook table -->
        <createTable tableName="audio_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_audio_book_book"
                             references="book(id)"/>
            </column>
            <column name="duration" type="INTEGER"/>
            <column name="narrator" type="VARCHAR(255)"/>
        </createTable>

        <!-- PrintedBook table -->
        <createTable tableName="printed_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_printed_book_book"
                             references="book(id)"/>
            </column>
            <column name="num_of_pages" type="INTEGER"/>
            <column name="hardcover" type="BOOLEAN"/>
        </createTable>

        <!-- EBook table -->
        <createTable tableName="e_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_e_book_book"
                             references="book(id)"/>
            </column>
            <column name="num_of_pages" type="INTEGER"/>
            <column name="size_mb" type="INTEGER"/>
        </createTable>

    </changeSet>



</databaseChangeLog>