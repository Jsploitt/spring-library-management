<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="moutaz">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="printed_book"/>
            </not>
        </preConditions>

        <createTable tableName="printed_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_printed_book_book"
                             references="book(id)"/>
            </column>
            <column name="num_of_pages" type="INT"/>
            <column name="hardcover" type="BOOLEAN"/>
        </createTable>
    </changeSet>

    <changeSet id="004" author="moutaz">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="audio_book"/>
            </not>
        </preConditions>

        <createTable tableName="audio_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_audio_book_book"
                             references="book(id)"/>
            </column>
            <column name="duration" type="INT"/>
            <column name="narrator" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="005" author="moutaz">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="e_book"/>
            </not>
        </preConditions>

        <createTable tableName="e_book">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"
                             foreignKeyName="fk_e_book_book"
                             references="book(id)"/>
            </column>
            <column name="num_of_pages" type="INT"/>
            <column name="size_mb" type="INT"/>
        </createTable>
    </changeSet>


    <changeSet id="006" author="moutaz">
        <preConditions onFail="MARK_RAN">
            <and>
                <columnExists tableName="e_book" columnName="size"/>
                <not>
                    <columnExists tableName="e_book" columnName="size_mb"/>
                </not>
            </and>
        </preConditions>

        <renameColumn tableName="e_book"
                      oldColumnName="size"
                      newColumnName="size_mb"
                      columnDataType="INT"/>
    </changeSet>

</databaseChangeLog>